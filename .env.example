# ============================================
# Scadium — Environment Variables Template
# Copy to .env and fill in values for local dev
# ============================================

# ------- Node env -------
NODE_ENV=development

# ------- Web (apps/web) -------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_APP_NAME=Scadium

# ------- API (apps/api) -------
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://scadium:scadium@localhost:5432/scadium?schema=public

# Redis — connection URL used by the shared RedisService (SIWS nonces, chat
# rate-limit, readiness probe). Defaults to redis://localhost:6379 if unset.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
# REQUIRED — ≥32 bytes; the API refuses to start without it (#33). No dev
# fallback: a known/short secret lets anyone forge an admin token. Generate one
# with e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC=https://api.devnet.solana.com
HOUSE_WALLET_SECRET_KEY=

# Provably fair
SERVER_SEED_ROTATION_INTERVAL=3600

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
# Stricter per-route profiles (#34). AUTH covers /auth/nonce|verify|refresh
# (nonce-grinding / signature spam); BET is the short-window burst cap on the
# money endpoints (crash bet/cashout, coinflip create/join, lottery ticket,
# jackpot enter). TTLs in seconds.
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=15
THROTTLE_BET_TTL=10
THROTTLE_BET_LIMIT=30
