# ============================================
# Scadium — Environment Variables Template
# Copy to .env and fill in values for local dev
# ============================================

# ------- Node env -------
NODE_ENV=development

# ------- Web (apps/web) -------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_APP_NAME=Scadium

# ------- API (apps/api) -------
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://scadium:scadium@localhost:5432/scadium?schema=public

# Redis — connection URL used by the shared RedisService (SIWS nonces, chat
# rate-limit, readiness probe). Defaults to redis://localhost:6379 if unset.
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
# REQUIRED — ≥32 bytes; the API refuses to start without it (#33). No dev
# fallback: a known/short secret lets anyone forge an admin token. Generate one
# with e.g. `openssl rand -base64 48`.
JWT_SECRET=change-me-in-production-use-a-long-random-string-min-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC=https://api.devnet.solana.com
HOUSE_WALLET_SECRET_KEY=

# Provably fair
SERVER_SEED_ROTATION_INTERVAL=3600

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
# Stricter per-route profiles (#34). AUTH covers /auth/nonce|verify|refresh
# (nonce-grinding / signature spam); BET is the short-window burst cap on the
# money endpoints (crash bet/cashout, coinflip create/join, lottery ticket,
# jackpot enter). TTLs in seconds.
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=15
THROTTLE_BET_TTL=10
THROTTLE_BET_LIMIT=30

# SIWS message binding (#37) — a signature is only valid for THIS deployment:
# domain/URI/chain are baked into the signed message, so a signature captured on
# another origin or cluster can never authenticate here. SOLANA_NETWORK (above)
# supplies the chain id.
SIWS_DOMAIN=localhost:3000
SIWS_URI=http://localhost:3000

# Observability (#38)
# Structured JSON logs (pino). Pretty-printed only when NODE_ENV=development.
LOG_LEVEL=info
# Error tracking — leave empty to disable Sentry entirely (no SDK init).
SENTRY_DSN=
# /docs is OFF when NODE_ENV=production; set true to re-enable on a protected
# staging box. /metrics (Prometheus) is always on — keep it firewalled/not
# proxied to the public edge.
DOCS_ENABLED=false

# Licensing / compliance (#41). The footer's "Licensed & regulated" claim is
# FAIL-CLOSED: it renders only when ALL THREE of these are set non-empty (and
# then shows the real licence number + regulator, not the generic phrase). Leave
# empty until a real licence is held — asserting one you do not hold is a legal
# misrepresentation. Surfaced to the web via GET /compliance/config.
LICENSE_NUMBER=
LICENSE_REGULATOR=
LICENSE_JURISDICTION=

# Geo-blocking / VPN (#43, hardened #149). The geo guard reads the request
# country from a trusted CDN/proxy header and blocks (HTTP 451) when it is in the
# blocklist (shared BLOCKED_COUNTRIES, or BLOCKED_COUNTRIES_OVERRIDE below). Raw
# client IPs are NEVER stored — only a salted hash in the GeoCheck audit trail.
# With REAL_MONEY_ENABLED the guard fails CLOSED: a request whose region cannot be
# verified is blocked. See docs/runbooks/trusted-proxy.md.
GEO_COUNTRY_HEADER=x-vercel-ip-country
# CSV override for the blocklist; empty = use the shared BLOCKED_COUNTRIES.
BLOCKED_COUNTRIES_OVERRIDE=
# Private salt for the audit IP hash. The default is INSECURE (reversible over the
# IPv4 space) — real money REFUSES TO BOOT unless this is set to a private value.
GEO_IP_SALT=change-me-geo-salt
# Shared secret the TRUSTED proxy echoes in `x-geo-proxy-secret` to prove the geo
# headers are authentic (#149). When set, requests without the matching secret are
# treated as unknown-region (→ fail-closed for real money), defeating a direct-to-
# origin caller that self-declares a permitted country. Empty = trust the CDN
# header as-is (play-money demo). MUST be set for real money behind a proxy that
# strips inbound copies of the geo headers — see docs/runbooks/trusted-proxy.md.
GEO_PROXY_SECRET=
# VPN/proxy detection — off by default. When 'true', requests scoring
# >= VPN_BLOCK_THRESHOLD (0..1) are blocked. Real money REFUSES TO BOOT if this is
# 'true' without VPN_PROVIDER_API_KEY (otherwise it silently scores 0 = no-op).
VPN_DETECTION_ENABLED=false
VPN_BLOCK_THRESHOLD=0.85
# IPQualityScore API key for live VPN/proxy scoring (#149). Empty = inactive.
VPN_PROVIDER_API_KEY=

# KYC / identity verification (#45). Off in play-money. When 'true', deposits and
# withdrawals require an APPROVED + sanctions-cleared verification (KycGuard). The
# provider (Sumsub/Onfido) SDK token is stubbed until a real key is wired; the
# webhook is HMAC-verified with KYC_WEBHOOK_SECRET.
KYC_ENABLED=false
KYC_WEBHOOK_SECRET=change-me-kyc-webhook-secret

# Real-money master switch (#49, #149). Fail-closed (off). The API REFUSES TO BOOT
# when this is 'true' unless: a licence is configured (LICENSE_* above), KYC is on
# (KYC_ENABLED), GEO_IP_SALT is a private value, and — if VPN_DETECTION_ENABLED —
# VPN_PROVIDER_API_KEY is set. Flipping this is a business-gated decision (a valid
# gaming licence must be held first).
REAL_MONEY_ENABLED=false
