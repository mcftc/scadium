# ============================================
# Scadium — Environment Variables Template
# Copy to .env and fill in values for local dev
# ============================================

# ------- Node env -------
NODE_ENV=development

# ------- Web (apps/web) -------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_APP_NAME=Scadium

# ------- API (apps/api) -------
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgresql://scadium:scadium@localhost:5432/scadium?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC=https://api.devnet.solana.com
HOUSE_WALLET_SECRET_KEY=

# Provably fair
SERVER_SEED_ROTATION_INTERVAL=3600

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
