# dependencies
node_modules
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage
*.lcov

# next.js
.next/
out/

# build output
dist/
build/
*.tsbuildinfo
# stale in-source tsc output (packages emit to dist/, source is .ts only)
packages/*/src/**/*.js
packages/*/src/**/*.js.map

# turbo
.turbo

# env
.env
.env*.local
.env.development
.env.production
# real prod compose secrets live on the VPS; the committed template is .env.prod.example
.env.prod
infra/.env.prod

# logs
logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Anchor / Solana
programs/**/target
programs/**/.anchor
test-ledger/

# Prisma
infra/prisma/*.db
infra/prisma/*.db-journal

# Local tool state (Claude Code session memory, Playwright MCP logs)
.remember/
.playwright-mcp/
.agents/
# skills-lock.json IS tracked (the manifest of shared agent skills, like pnpm-lock.yaml);
# .agents/ stays ignored (the skill content) — run `npx skills experimental_install` to restore.
.keys/

# Claude Code: ignore local/session state, but TRACK the shared dev pipeline
# (agents + commands + docs) so every contributor gets it on clone.
.claude/*
!.claude/agents/
!.claude/commands/
!.claude/README.md
.claude/settings.local.json

# Rust/Anchor build artifacts — but TRACK the generated IDL + TS types and the
# devnet program keypairs (#25): the IDLs are the on-chain ABI the setup
# scripts/tests consume, and the keypairs pin the deployed program ids to the
# declare_id! values. NOTE: `dir/` can't be re-included from inside, hence the
# `target/*` + negation form.
target/*
!target/idl/
!target/types/
!target/deploy/
target/deploy/*
!target/deploy/*-keypair.json

# firecrawl scrape cache
.firecrawl/
.preview-shots/

# Playwright e2e artifacts (#142)
apps/web/playwright-report/
apps/web/test-results/
apps/web/blob-report/
.vercel
.env*
