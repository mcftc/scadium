// Scadium Prisma schema — single source of truth for the Postgres DB.
// Run migrations with `pnpm --filter @scadium/api prisma migrate dev`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  user
  moderator
  admin
}

enum GameType {
  crash
  coinflip
  blackjack
  lottery
  jackpot
}

enum LotteryDrawStatus {
  open
  drawn
}

enum JackpotRoundStatus {
  open
  drawn
  refunded
}

enum BetStatus {
  pending
  won
  lost
  refunded
}

enum CrashRoundStatus {
  waiting
  running
  busted
}

enum CoinflipStatus {
  open
  matched
  resolving
  completed
  cancelled
}

enum BlackjackTableStatus {
  waiting
  betting
  dealing
  player_turns
  dealer_turn
  settling
}

// ==================== USERS & AUTH ====================

model User {
  id             String   @id @default(uuid()) @db.Uuid
  walletAddress  String   @unique
  username       String?  @unique
  avatarUrl      String?
  role           Role     @default(user)
  refCode        String   @unique
  referredById   String?  @db.Uuid
  referredBy     User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]   @relation("Referrals")
  banned         Boolean  @default(false)
  banReason      String?
  totalWagered   BigInt   @default(0)
  totalWon       BigInt   @default(0)
  totalLost      BigInt   @default(0)
  biggestWin     BigInt   @default(0)
  gamesPlayed    Int      @default(0)
  scadiumBalance BigInt   @default(0)
  // Play-money balance used by the off-chain game loop until on-chain
  // programs land. New users get 10 SOL equivalent (10_000_000_000 lamports).
  // Once the vault is live this becomes a CACHE of the on-chain UserVault
  // balance (reconciled periodically) — fast validation stays in Postgres.
  playBalanceLamports BigInt @default(10000000000)
  // On-chain custody (Phase A): UserVault PDA address once the user has
  // deposited at least once; null = never deposited (still play-money).
  vaultAddress   String?  @unique
  lastDailyCaseAt DateTime?
  // totalLost watermark at the last cashback claim — cashback accrues on
  // the delta since this baseline (Phase C).
  cashbackBaselineLost BigInt @default(0)
  rewardClaims   RewardClaim[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions       Session[]
  bets           Bet[]
  chatMessages   ChatMessage[]
  crashBets      CrashBet[]
  coinflipsMade  CoinflipGame[] @relation("creator")
  coinflipsJoined CoinflipGame[] @relation("joiner")
  airdropClaims  AirdropClaim[]
  referralsAsReferrer Referral[] @relation("referrer")
  referralsAsReferee  Referral[] @relation("referee")
  lotteryTickets LotteryTicket[]
  jackpotEntries JackpotEntry[]
  jackpotWins    JackpotRound[] @relation("jackpotWinner")

  @@index([walletAddress])
  @@index([refCode])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jwtId        String   @unique
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

model AuthNonce {
  walletAddress String   @id
  nonce         String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}

// ==================== FAIRNESS ====================

model Seed {
  id              String    @id @default(uuid()) @db.Uuid
  serverSeedHash  String    @unique
  serverSeed      String?   @unique
  clientSeed      String
  nonce           Int       @default(0)
  revealedAt      DateTime?
  createdAt       DateTime  @default(now())

  crashRounds   CrashRound[]
  coinflips     CoinflipGame[]
  blackjackRounds BlackjackRound[]
  lotteryDraws  LotteryDraw[]
  jackpotRounds JackpotRound[]
}

// ==================== BETS (unified history) ====================

model Bet {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation(fields: [userId], references: [id])
  gameType        GameType
  amountLamports  BigInt
  payoutLamports  BigInt    @default(0)
  multiplier      Float?
  status          BetStatus @default(pending)
  txSignature     String?
  seedId          String?   @db.Uuid
  nonce           Int?
  resultJson      Json?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([gameType, createdAt])
}

// ==================== CRASH ====================

model CrashRound {
  id              String            @id @default(uuid()) @db.Uuid
  seedId          String            @db.Uuid
  seed            Seed              @relation(fields: [seedId], references: [id])
  nonce           Int
  status          CrashRoundStatus  @default(waiting)
  bustMultiplier  Float?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime          @default(now())

  bets CrashBet[]

  @@index([status, createdAt])
}

model CrashBet {
  id                    String   @id @default(uuid()) @db.Uuid
  roundId               String   @db.Uuid
  round                 CrashRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId                String   @db.Uuid
  user                  User     @relation(fields: [userId], references: [id])
  amountLamports        BigInt
  autoCashoutMultiplier Float?
  cashoutMultiplier     Float?
  payoutLamports        BigInt   @default(0)
  won                   Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@index([roundId])
  @@index([userId])
}

// ==================== COINFLIP ====================

model CoinflipGame {
  id             String         @id @default(uuid()) @db.Uuid
  creatorId      String         @db.Uuid
  creator        User           @relation("creator", fields: [creatorId], references: [id])
  creatorSide    String         // 'heads' | 'tails'
  joinerId       String?        @db.Uuid
  joiner         User?          @relation("joiner", fields: [joinerId], references: [id])
  amountLamports BigInt
  result         String?        // 'heads' | 'tails'
  winnerId       String?        @db.Uuid
  status         CoinflipStatus @default(open)
  seedId         String?        @db.Uuid
  seed           Seed?          @relation(fields: [seedId], references: [id])
  nonce          Int?
  txSignature    String?
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?

  @@index([status, createdAt])
  @@index([creatorId])
}

// ==================== LOTTERY ====================

model LotteryDraw {
  id           String            @id @default(uuid()) @db.Uuid
  // Monotonic on-chain draw index (PDA seed). Null for legacy off-chain draws.
  drawIndex    BigInt?           @unique
  commitTxSignature String?
  revealTxSignature String?
  seedId       String            @db.Uuid
  seed         Seed              @relation(fields: [seedId], references: [id])
  nonce        Int               @default(0)
  status       LotteryDrawStatus @default(open)
  // Result (null until drawn): 5 main numbers (1..36) + 1 bonus (1..10)
  mainNumbers  Int[]
  bonusNumber  Int?
  potLamports  BigInt            @default(0)
  ticketCount  Int               @default(0)
  drawAt       DateTime // when this draw is scheduled to resolve
  drawnAt      DateTime?
  createdAt    DateTime          @default(now())

  tickets LotteryTicket[]

  @@index([status, drawAt])
}

model LotteryTicket {
  id             String      @id @default(uuid()) @db.Uuid
  drawId         String      @db.Uuid
  draw           LotteryDraw @relation(fields: [drawId], references: [id])
  userId         String      @db.Uuid
  user           User        @relation(fields: [userId], references: [id])
  mainNumbers    Int[] // the 5 picked main numbers
  bonusNumber    Int // the picked bonus number
  costLamports   BigInt
  matchedMain    Int         @default(0)
  matchedBonus   Int         @default(0)
  payoutLamports BigInt      @default(0)
  won            Boolean     @default(false)
  // On-chain era (Phase E): purchase tx (user-signed USDT transfer), prize
  // payout tx, bc.game tier, USDT amounts, and the free-ticket flag
  // (zero-match tickets re-enter the next draw on the house).
  txSignature    String?     @unique
  prizeTxSignature String?
  tier           String?
  payoutUsdtBase BigInt      @default(0)
  free           Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@index([drawId])
  @@index([userId, createdAt])
}

// ==================== JACKPOT ====================

model JackpotRound {
  id             String             @id @default(uuid()) @db.Uuid
  seedId         String             @db.Uuid
  seed           Seed               @relation(fields: [seedId], references: [id])
  nonce          Int                @default(0)
  status         JackpotRoundStatus @default(open)
  totalLamports  BigInt             @default(0) // sum of all entries
  winnerId       String?            @db.Uuid
  winner         User?              @relation("jackpotWinner", fields: [winnerId], references: [id])
  winningTicket  BigInt? // the drawn lamport index in [0, totalLamports)
  payoutLamports BigInt             @default(0) // amount paid to the winner (after edge)
  closeAt        DateTime // when the open window ends and the draw runs
  drawnAt        DateTime?
  createdAt      DateTime           @default(now())

  entries JackpotEntry[]

  @@index([status, closeAt])
}

model JackpotEntry {
  id             String       @id @default(uuid()) @db.Uuid
  roundId        String       @db.Uuid
  round          JackpotRound @relation(fields: [roundId], references: [id])
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id])
  amountLamports BigInt
  createdAt      DateTime     @default(now())

  @@index([roundId])
  @@index([userId, createdAt])
}

// ==================== BLACKJACK ====================

model BlackjackTable {
  id                String                @id @default(uuid()) @db.Uuid
  name              String
  status            BlackjackTableStatus  @default(waiting)
  minBetLamports    BigInt
  maxBetLamports    BigInt
  maxSeats          Int                   @default(5)
  createdAt         DateTime              @default(now())

  rounds BlackjackRound[]
}

model BlackjackRound {
  id         String         @id @default(uuid()) @db.Uuid
  tableId    String         @db.Uuid
  table      BlackjackTable @relation(fields: [tableId], references: [id])
  seedId     String         @db.Uuid
  seed       Seed           @relation(fields: [seedId], references: [id])
  nonce      Int
  stateJson  Json
  endedAt    DateTime?
  createdAt  DateTime       @default(now())

  @@index([tableId, createdAt])
}

// ==================== CHAT ====================

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id])
  body       String
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ==================== AIRDROPS / REWARDS ====================

model AirdropEvent {
  id              String   @id @default(uuid()) @db.Uuid
  distributedAt   DateTime @default(now())
  totalLamports   BigInt
  participantCount Int

  claims AirdropClaim[]
}

model AirdropClaim {
  id             String       @id @default(uuid()) @db.Uuid
  eventId        String       @db.Uuid
  event          AirdropEvent @relation(fields: [eventId], references: [id])
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id])
  lamports       BigInt
  txSignature    String?
  claimedAt      DateTime     @default(now())

  @@unique([eventId, userId])
}

// $SCAD reward claims (Phase C) — one row per on-chain claim_reward call.
// `period` mirrors the on-chain ClaimRecord PDA seed so the DB and chain
// dedupe agree (dailyCase = YYYYMMDD, airdrop = epoch-hour, others = epoch-ms).
model RewardClaim {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id])
  kind        RewardKind
  period      BigInt
  amountScad  BigInt // SCAD base units (9 decimals)
  txSignature String?
  createdAt   DateTime   @default(now())

  @@unique([userId, kind, period])
  @@index([userId, createdAt])
}

enum RewardKind {
  wagerReward
  cashback
  dailyCase
  airdrop
}

// Buy-and-burn ledger (Phase D): 20% of NGR swapped SOL→SCAD then burned.
model TokenBurn {
  id           String   @id @default(uuid()) @db.Uuid
  scadBurned   BigInt // SCAD base units
  solSpent     BigInt // lamports swapped in
  swapSignature String?
  burnSignature String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// ==================== AFFILIATE ====================

model Referral {
  id                  String   @id @default(uuid()) @db.Uuid
  referrerId          String   @db.Uuid
  referrer            User     @relation("referrer", fields: [referrerId], references: [id])
  refereeId           String   @unique @db.Uuid
  referee             User     @relation("referee", fields: [refereeId], references: [id])
  volumeLamports      BigInt   @default(0)
  commissionLamports  BigInt   @default(0)
  createdAt           DateTime @default(now())
}

// ==================== LEADERBOARD ====================

model LeaderboardSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  period         String   // 'hourly' | 'daily' | 'weekly' | 'all_time'
  userId         String   @db.Uuid
  volumeLamports BigInt
  rank           Int
  capturedAt     DateTime @default(now())

  @@index([period, capturedAt, rank])
}
