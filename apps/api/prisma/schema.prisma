// Scadium Prisma schema — single source of truth for the Postgres DB.
// Run migrations with `pnpm --filter @scadium/api prisma migrate dev`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  // Generate the alpine-musl engine alongside native so the prod image
  // (node:20-alpine) can run migrate/queries. Without this + openssl in the
  // image, the engine defaults to openssl-1.1.x and fails to load (#81).
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  user
  moderator
  admin
}

enum GameType {
  crash
  coinflip
  blackjack
  lottery
  jackpot
  // Phase: dual-currency expansion — provably-fair game catalog.
  dice
  limbo
  wheel
  plinko
  mines
  hilo
  tower
}

// Dual-currency model (sweepstakes): `jeton` is the bought, NON-redeemable
// wagering balance (User.playBalanceLamports); `scad` is the earned, REDEEMABLE
// reward balance (User.scadiumBalance). The ledger tags every movement so the
// two are never conflated and an audit can prove bought money never cashed out.
enum Currency {
  jeton
  scad
  // SCAD Engine: `scad_staked` is the locked, dividend-earning staked balance
  // (User.scadiumStaked); `usds` is the USD-pegged dividend payout balance
  // (User.usdsBalance). Like scad, both are tagged so audits never conflate them
  // with bought Jeton.
  scad_staked
  usds
  // SCAD Vault: `scad_vault` is $SCAD locked into a term-staking vault position
  // (sum of the user's VaultPosition principals). Tagged like scad_staked so the
  // ledger never conflates vault-locked SCAD with spendable or Engine-staked SCAD.
  scad_vault
}

// Where money entered to buy Jeton. App-store rails (google_play/apple_iap) and
// card rails (stripe) may ONLY sell non-redeemable Jeton — redemption of `scad`
// is web-only (enforced by the channel guard), keeping us inside store policy.
enum PaymentProvider {
  stripe
  moonpay
  transak
  solana_pay
  google_play
  apple_iap
}

enum PurchaseStatus {
  pending
  paid
  fulfilled
  refunded
  failed
  chargeback
}

enum LotteryDrawStatus {
  open
  drawn
}

enum JackpotRoundStatus {
  open
  drawn
  refunded
}

enum BetStatus {
  pending
  won
  lost
  refunded
}

enum CrashRoundStatus {
  waiting
  running
  busted
}

enum CoinflipStatus {
  open
  matched
  resolving
  completed
  cancelled
}

enum BlackjackTableStatus {
  waiting
  betting
  dealing
  player_turns
  dealer_turn
  settling
}

enum KycStatus {
  none
  pending
  approved
  rejected
}

// ==================== USERS & AUTH ====================

model User {
  id                        String        @id @default(uuid()) @db.Uuid
  walletAddress             String        @unique
  // How this account authenticates. 'siws' = external Solana wallet (default,
  // unchanged). 'privy' = email/social login with a Privy-managed embedded
  // Solana wallet, whose address is stored in walletAddress. Both share the same
  // Session/JWT layer and the same downstream compliance gates.
  authProvider              String        @default("siws")
  privyUserId               String?       @unique
  custodial                 Boolean       @default(false)
  username                  String?       @unique
  avatarUrl                 String?
  // Optional contact + linked socials (Settings). Social fields hold the
  // linked handle/email per provider; null = not connected.
  email                     String?
  googleAccount             String?
  telegramAccount           String?
  discordAccount            String?
  // Notification preferences.
  notifyEmailWins           Boolean       @default(false)
  notifyMarketing           Boolean       @default(false)
  role                      Role          @default(user)
  refCode                   String        @unique
  referredById              String?       @db.Uuid
  referredBy                User?         @relation("Referrals", fields: [referredById], references: [id])
  referrals                 User[]        @relation("Referrals")
  banned                    Boolean       @default(false)
  banReason                 String?
  totalWagered              BigInt        @default(0)
  totalWon                  BigInt        @default(0)
  totalLost                 BigInt        @default(0)
  biggestWin                BigInt        @default(0)
  gamesPlayed               Int           @default(0)
  scadiumBalance            BigInt        @default(0)
  // SCAD locked by a PENDING on-chain reward claim (#28) - moved out of
  // scadiumBalance at claim time, finalized on confirm or RESTORED to
  // scadiumBalance on permanent failure. Never spendable.
  scadiumReserved           BigInt        @default(0)
  // SCAD Engine (bc.game parity): $SCAD that has been staked. Locked until
  // `stakeLockedUntil`; earns a pro-rata USDS dividend each distribution round.
  // Moved out of scadiumBalance on stake, back on unstake (after the lock).
  scadiumStaked             BigInt        @default(0)
  stakeLockedUntil          DateTime?
  // SCAD Vault: $SCAD locked into term-staking vault positions — the running
  // total of this user's VaultPosition principals (the ledger aggregate for the
  // `scad_vault` currency). The position's CURRENT value is shares × pool index;
  // this column is the principal mirror, kept by applyBalanceDelta like staked.
  scadiumVault              BigInt        @default(0)
  // SCAD Engine auto-stake preference (bc.game parity). When true, earned $SCAD
  // is swept into the locked staked balance on the next staking touch (summary/
  // claim path) once it clears ENGINE.MIN_STAKE_SCAD_BASE — see StakingService
  // `autoStakeSweep`. Defaults to ENGINE.AUTO_STAKE_DEFAULT (true).
  autoStakeEnabled          Boolean       @default(true)
  // USDS (USD-pegged dividend stablecoin, 6 decimals) earned from staking.
  // `usdsReserved` mirrors scadiumReserved: USDS locked by a PENDING on-chain
  // dividend claim, finalized on confirm or restored on permanent failure.
  usdsBalance               BigInt        @default(0)
  usdsReserved              BigInt        @default(0)
  // Play-money balance used by the off-chain game loop until on-chain
  // programs land. New users get 10 SOL equivalent (10_000_000_000 lamports).
  // Once the vault is live this becomes a CACHE of the on-chain UserVault
  // balance (reconciled periodically) — fast validation stays in Postgres.
  playBalanceLamports       BigInt        @default(10000000000)
  // On-chain custody (Phase A): UserVault PDA address once the user has
  // deposited at least once; null = never deposited (still play-money).
  vaultAddress              String?       @unique
  lastDailyCaseAt           DateTime?
  // "Reset Stats" timestamp — when set, the lifetime stats grid counts only
  // bets settled after this instant (computed from the Bet table). null =
  // show the denormalized User aggregate columns (fast path).
  statsResetAt              DateTime?
  // 18+ age-gate acknowledgement (#44). Set once on first confirm; null = not
  // yet acknowledged. Idempotent (keeps the earliest timestamp).
  ageConfirmedAt            DateTime?
  // Legal-acceptance record (#48): the LEGAL_VERSION the user last accepted and
  // when. The acceptance gate re-triggers when this differs from the current
  // LEGAL_VERSION. null = never accepted.
  acceptedLegalVersion      String?
  acceptedLegalAt           DateTime?
  // Responsible-gambling controls (#46). Self-exclusion blocks login + play;
  // cooling-off blocks play only. Both, once set, cannot be SHORTENED before
  // they expire (server-enforced). Daily limits (lamports) gate wagering;
  // null = no limit. Today's usage is computed from the Bet ledger.
  selfExcludedUntil         DateTime?
  coolOffUntil              DateTime?
  dailyDepositLimitLamports BigInt?
  dailyLossLimitLamports    BigInt?
  dailyWagerLimitLamports   BigInt?
  // Salted hash of the signup IP (#47) — same-IP referrer/referee pairs are
  // flagged as sybil and accrue no commission. Raw IPs are never stored.
  signupIpHash              String?
  // KYC / identity verification (#45). Hard-gates deposits/withdrawals when KYC
  // is enabled. We store only the provider reference + status — never raw
  // identity documents.
  kycStatus                 KycStatus     @default(none)
  kycProviderRef            String?
  sanctionsCleared          Boolean       @default(false)
  kycReviewedAt             DateTime?
  // totalLost watermark at the last cashback claim — cashback accrues on
  // the delta since this baseline (Phase C).
  cashbackBaselineLost      BigInt        @default(0)
  // totalWagered watermark for free lottery tickets — every 1 SOL wagered
  // above this earns one; consuming a ticket advances it by 1 SOL.
  freeTicketBaselineWagered BigInt        @default(0)
  rewardClaims              RewardClaim[]
  // Per-user provably-fair seed state (Phase I #18): player-controlled client
  // seed + monotonic nonce + the active/pre-committed server-seed pair.
  clientSeedState           ClientSeed?
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  sessions             Session[]
  vaultTransfers       VaultTransfer[]
  vaultPositions       VaultPosition[]
  bets                 Bet[]
  chatMessages         ChatMessage[]
  crashBets            CrashBet[]
  scheduledCrashBets   ScheduledCrashBet[]
  coinflipsMade        CoinflipGame[]        @relation("creator")
  coinflipsJoined      CoinflipGame[]        @relation("joiner")
  airdropClaims        AirdropClaim[]
  referralsAsReferrer  Referral[]            @relation("referrer")
  referralsAsReferee   Referral[]            @relation("referee")
  lotteryTickets       LotteryTicket[]
  jackpotEntries       JackpotEntry[]
  jackpotWins          JackpotRound[]        @relation("jackpotWinner")
  linkedWallets        LinkedWallet[]
  balanceLedger        BalanceLedger[]
  stakeEvents          StakeEvent[]
  distributionClaims   DistributionClaim[]
  purchases            Purchase[]
  wagerLeaderboards    WagerLeaderboard[]
  reconciliationDrifts ReconciliationDrift[]
  auditLogsAsActor     AuditLog[]            @relation("auditActor")
  auditLogsAsTarget    AuditLog[]            @relation("auditTarget")

  @@index([walletAddress])
  @@index([refCode])
}

// Additional Solana wallets linked to an account (beyond the primary
// User.walletAddress). Sign-in with any linked address resolves to the owning
// user; ownership is proven once via a SIWS signature at link time.
model LinkedWallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String   @unique
  createdAt DateTime @default(now())

  @@index([userId])
}

model Session {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // jti of the CURRENT access token bound to this session. The guard rejects any
  // access token whose jti != this (so rotation/logout invalidate old tokens).
  jwtId            String   @unique
  // SHA-256 of the current refresh token (never the raw token). @unique so a
  // presented token resolves to exactly one session.
  refreshToken     String   @unique
  // SHA-256 of the PREVIOUS (rotated-out) refresh token (#35). Replaying it is a
  // reuse signal → the whole session is revoked.
  prevRefreshToken String?
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
}

// Append-only double-entry ledger (Phase G): one row per playBalance movement,
// written in the SAME transaction as the mutation via `applyBalanceDelta`. This
// makes `User.playBalanceLamports` a re-derivable projection — SUM(delta) per
// user must equal the live balance, and `balanceAfter` is the running sum at the
// time the row was written. Never updated or deleted by application code.
// Verified on-chain vault transfers (#27): one row per confirmed deposit /
// withdraw signature — @unique makes crediting idempotent (a replayed
// signature inserts nothing and credits nothing).
model VaultTransfer {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  txSignature    String   @unique
  kind           String // 'deposit' | 'withdraw'
  amountLamports BigInt
  createdAt      DateTime @default(now())

  @@index([userId, createdAt])
}

model BalanceLedger {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  // Which balance moved. Defaults to `jeton` so every pre-existing row (all of
  // which were playBalance movements) keeps its meaning with no backfill.
  currency     Currency @default(jeton)
  delta        BigInt
  reason       String
  refType      String
  refId        String?
  balanceAfter BigInt
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// Jeton purchase / fulfillment record — the idempotency + audit backbone of the
// payments module. One row per payment attempt; `@@unique([provider, providerRef])`
// makes webhook fulfillment idempotent (a replayed event inserts nothing and
// credits nothing — same discipline as VaultTransfer.txSignature). `channel`
// records whether the money came in via web or the mobile shell, so an audit can
// prove app-store/IAP money only ever bought non-redeemable Jeton.
model Purchase {
  id            String          @id @default(uuid()) @db.Uuid
  userId        String          @db.Uuid
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      PaymentProvider
  providerRef   String // Stripe session/PI id, IAP transaction id, or tx signature
  jetonLamports BigInt          @default(0) // Jeton credited; 0 until fulfilled
  priceCurrency String // 'usd' | 'usdc' | 'sol'
  priceMinor    BigInt // cents / token base units paid
  status        PurchaseStatus  @default(pending)
  channel       String          @default("web") // 'web' | 'mobile'
  createdAt     DateTime        @default(now())
  fulfilledAt   DateTime?

  @@unique([provider, providerRef])
  @@index([userId, createdAt])
}

// Reconciliation drift log (Phase G): the hourly reconciliation job recomputes
// per-user aggregates from `Bet` + `BalanceLedger` and, for each User column
// that disagrees with the recomputed value, appends one flag row here. The job
// NEVER mutates the User row — it only flags. `storedValue`/`derivedValue` are
// stringified (lamports are BigInt; gamesPlayed is an Int) for safe transport.
model ReconciliationDrift {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  field        String
  storedValue  String
  derivedValue String
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// Append-only audit log (Phase G) for privileged admin actions (ban / unban /
// forced airdrop distribution). Written in the SAME transaction as the action
// it records so the audit row commits (or rolls back) atomically with the
// effect. Never updated or deleted by application code.
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String   @db.Uuid
  actor        User     @relation("auditActor", fields: [actorUserId], references: [id])
  action       String
  targetUserId String?  @db.Uuid
  target       User?    @relation("auditTarget", fields: [targetUserId], references: [id])
  metadataJson Json?
  createdAt    DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

// ==================== FAIRNESS ====================

/// Per-user rotating provably-fair seed state (Phase I #18). One row per user:
/// the player-controlled `clientSeed`, a monotonic `nonce`, the ACTIVE
/// server-seed pair (secret until rotated) and a PRE-COMMITTED next pair. On
/// rotation the active `serverSeed` is revealed and `next*` is promoted. Distinct
/// from the per-round `Seed` rows the game engines create.
model ClientSeed {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @db.Uuid
  user               User      @relation(fields: [userId], references: [id])
  clientSeed         String
  nonce              BigInt    @default(0)
  serverSeed         String
  serverSeedHash     String
  nextServerSeed     String
  nextServerSeedHash String
  createdAt          DateTime  @default(now())
  rotatedAt          DateTime?
}

model Seed {
  id             String    @id @default(uuid()) @db.Uuid
  serverSeedHash String    @unique
  serverSeed     String?   @unique
  clientSeed     String
  nonce          Int       @default(0)
  revealedAt     DateTime?
  createdAt      DateTime  @default(now())

  crashRounds     CrashRound[]
  coinflips       CoinflipGame[]
  blackjackRounds BlackjackRound[]
  lotteryDraws    LotteryDraw[]
  jackpotRounds   JackpotRound[]
}

// ==================== BETS (unified history) ====================

model Bet {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @db.Uuid
  user           User      @relation(fields: [userId], references: [id])
  gameType       GameType
  amountLamports BigInt
  payoutLamports BigInt    @default(0)
  multiplier     Float?
  status         BetStatus @default(pending)
  txSignature    String?
  seedId         String?   @db.Uuid
  nonce          Int?
  resultJson     Json?
  createdAt      DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([gameType, createdAt])
}

// ==================== CRASH ====================

model CrashRound {
  id             String           @id @default(uuid()) @db.Uuid
  seedId         String           @db.Uuid
  seed           Seed             @relation(fields: [seedId], references: [id])
  nonce          Int
  status         CrashRoundStatus @default(waiting)
  bustMultiplier Float?
  startedAt      DateTime?
  endedAt        DateTime?
  createdAt      DateTime         @default(now())
  // On-chain entropy (ADR 0002 / #101), only populated when CRASH_ONCHAIN_ENTROPY
  // is on: the round pins a future `targetSlot` at open and derives the bust from
  // that slot's hash once it passes (unknown/unchooseable at commit). null on the
  // play-money default path.
  entropyStatus  String?
  targetSlot     BigInt?
  slotHash       String?

  bets CrashBet[]

  @@index([status, createdAt])
}

model CrashBet {
  id                    String     @id @default(uuid()) @db.Uuid
  roundId               String     @db.Uuid
  round                 CrashRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId                String     @db.Uuid
  user                  User       @relation(fields: [userId], references: [id])
  amountLamports        BigInt
  // Stake still riding (RAM-only until persisted at bet/cashout time). Shrinks
  // to 0 on a full cashout and on settle/recovery; recovery refunds whatever
  // remains so a crashed mid-round bet is never stranded.
  remainingLamports     BigInt     @default(0)
  autoCashoutMultiplier Float?
  cashoutMultiplier     Float?
  payoutLamports        BigInt     @default(0)
  won                   Boolean    @default(false)
  createdAt             DateTime   @default(now())

  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId])
}

// A next-round crash bet whose stake has been DEBITED but whose round has not
// opened yet. Persisted at schedule time (in the same tx as the debit) so a
// restart in the window before `startNewRound` drains the in-memory queue can
// still refund the stake (#72). The row is deleted atomically when the bet is
// drained into a real CrashBet, when cancelled, or when refunded on boot
// recovery. One scheduled bet per user (mirrors the engine's in-memory Map).
model ScheduledCrashBet {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @db.Uuid
  user                  User     @relation(fields: [userId], references: [id])
  amountLamports        BigInt
  autoCashoutMultiplier Float?
  createdAt             DateTime @default(now())
}

// ==================== COINFLIP ====================

model CoinflipGame {
  id             String         @id @default(uuid()) @db.Uuid
  creatorId      String         @db.Uuid
  creator        User           @relation("creator", fields: [creatorId], references: [id])
  creatorSide    String // 'heads' | 'tails'
  joinerId       String?        @db.Uuid
  joiner         User?          @relation("joiner", fields: [joinerId], references: [id])
  amountLamports BigInt
  result         String? // 'heads' | 'tails'
  winnerId       String?        @db.Uuid
  status         CoinflipStatus @default(open)
  seedId         String?        @db.Uuid
  seed           Seed?          @relation(fields: [seedId], references: [id])
  nonce          Int?
  txSignature    String?
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?

  @@index([status, createdAt])
  @@index([creatorId])
}

// ==================== LOTTERY ====================

model LotteryDraw {
  id                      String            @id @default(uuid()) @db.Uuid
  // Monotonic on-chain draw index (PDA seed). Null for legacy off-chain draws.
  drawIndex               BigInt?           @unique
  commitTxSignature       String?
  revealTxSignature       String?
  seedId                  String            @db.Uuid
  seed                    Seed              @relation(fields: [seedId], references: [id])
  nonce                   Int               @default(0)
  status                  LotteryDrawStatus @default(open)
  // Result (empty until drawn): the 6 winning digits (each 0..9), index 0 =
  // leftmost. Tickets win the highest bracket whose leading digits all match.
  winningDigits           Int[]
  // Hex of the 32-byte slot hash mixed into the draw entropy (null until
  // drawn; synthetic sha256(seed:clientSeed) when the chain is disabled).
  slotHash                String?
  // Slot PINNED at commit time (#19b): reveal must derive from THIS slot's hash,
  // not the newest, so the cosigner can't grind the reveal. Null for off-chain /
  // synthetic draws. Surfaced in the snapshot so the verifier can show it.
  targetSlot              BigInt?
  // Entropy provenance (#19a): 'onchain' = derived from a real on-chain
  // SlotHashes reveal (provably fair); 'synthetic-not-fair' = settled via the
  // operator-deterministic synthetic fallback (NOT provably fair — surfaced as
  // such). null until drawn.
  fairness                String?
  // PancakeSwap-style $SCAD economy (all base units, 9 decimals):
  ticketPriceScadBase     BigInt            @default(0) // price per ticket this round
  injectionScadBase       BigInt            @default(0) // house injection added to the pool
  rolloverScadBase        BigInt            @default(0) // unwon slices carried in from prior round
  totalPoolScadBase       BigInt            @default(0) // sales(discounted) + injection + rollover
  burnScadBase            BigInt            @default(0) // 20% treasury slice burned at settle
  bracketWinnerCounts     Int[] // [6] winners per bracket
  bracketAmountsScadBase  BigInt[] // [6] slice per bracket
  bracketRolloverScadBase BigInt[] // [6] unwon slice rolled forward
  // SOL-equivalent of the round's ticket sales — kept ONLY for the unified Bet
  // ledger / aggregates (real value moves in $SCAD).
  potLamports             BigInt            @default(0)
  ticketCount             Int               @default(0)
  drawAt                  DateTime // when this draw is scheduled to resolve
  drawnAt                 DateTime?
  createdAt               DateTime          @default(now())

  tickets LotteryTicket[]

  @@index([status, drawAt])
}

model LotteryTicket {
  id               String      @id @default(uuid()) @db.Uuid
  drawId           String      @db.Uuid
  draw             LotteryDraw @relation(fields: [drawId], references: [id])
  userId           String      @db.Uuid
  user             User        @relation(fields: [userId], references: [id])
  digits           Int[] // the 6 picked digits (each 0..9), index 0 = leftmost
  // SOL-equiv mirrors for the unified Bet ledger; real value is the *ScadBase.
  costLamports     BigInt
  payoutLamports   BigInt      @default(0)
  costScadBase     BigInt      @default(0) // $SCAD actually paid (after bulk-discount share)
  payoutScadBase   BigInt      @default(0) // $SCAD prize from its bracket's equal split
  matchLen         Int         @default(0) // leading digits matched (0..6)
  bracket          Int? // highest bracket won (0..5), null if no win
  won              Boolean     @default(false)
  // On-chain era: purchase tx (user-signed $SCAD transfer), prize payout tx,
  // and the free-ticket flag (loyalty entry on the house).
  // A bulk buy_tickets tx records N tickets under one signature — txIndex is
  // the ticket's position in the batch; (txSignature, txIndex) blocks replays.
  txSignature      String?
  txIndex          Int         @default(0)
  prizeTxSignature String?
  free             Boolean     @default(false)
  createdAt        DateTime    @default(now())

  @@unique([txSignature, txIndex])
  @@index([drawId])
  @@index([userId, createdAt])
}

// ==================== JACKPOT ====================

model JackpotRound {
  id             String             @id @default(uuid()) @db.Uuid
  seedId         String             @db.Uuid
  seed           Seed               @relation(fields: [seedId], references: [id])
  nonce          Int                @default(0)
  status         JackpotRoundStatus @default(open)
  totalLamports  BigInt             @default(0) // sum of all entries
  winnerId       String?            @db.Uuid
  winner         User?              @relation("jackpotWinner", fields: [winnerId], references: [id])
  winningTicket  BigInt? // the drawn lamport index in [0, totalLamports)
  payoutLamports BigInt             @default(0) // amount paid to the winner (after edge)
  closeAt        DateTime // when the open window ends and the draw runs
  drawnAt        DateTime?
  createdAt      DateTime           @default(now())

  entries JackpotEntry[]

  @@index([status, closeAt])
}

model JackpotEntry {
  id             String       @id @default(uuid()) @db.Uuid
  roundId        String       @db.Uuid
  round          JackpotRound @relation(fields: [roundId], references: [id])
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id])
  amountLamports BigInt
  createdAt      DateTime     @default(now())

  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId, createdAt])
}

// ==================== BLACKJACK ====================

model BlackjackTable {
  id             String               @id @default(uuid()) @db.Uuid
  name           String
  status         BlackjackTableStatus @default(waiting)
  minBetLamports BigInt
  maxBetLamports BigInt
  maxSeats       Int                  @default(5)
  createdAt      DateTime             @default(now())

  rounds BlackjackRound[]
}

model BlackjackRound {
  id        String         @id @default(uuid()) @db.Uuid
  tableId   String         @db.Uuid
  table     BlackjackTable @relation(fields: [tableId], references: [id])
  seedId    String         @db.Uuid
  seed      Seed           @relation(fields: [seedId], references: [id])
  nonce     Int
  stateJson Json
  endedAt   DateTime?
  createdAt DateTime       @default(now())

  @@index([tableId, createdAt])
}

// ==================== CHAT ====================

model ChatMessage {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  body      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([createdAt])
}

// ==================== AIRDROPS / REWARDS ====================

model AirdropEvent {
  id               String   @id @default(uuid()) @db.Uuid
  distributedAt    DateTime @default(now())
  totalLamports    BigInt
  participantCount Int

  claims AirdropClaim[]
}

// Accumulating pool for the CURRENT hour (solpump left-rail airdrop widget).
// Survives API restarts because tips debit real play balances. One row per
// hour (`period` = YYYYMMDDHH UTC); flipped to distributed by the engine.
model AirdropPool {
  id           String   @id @default(uuid()) @db.Uuid
  period       String   @unique
  baseLamports BigInt   @default(0)
  tipLamports  BigInt   @default(0)
  tipsCount    Int      @default(0)
  distributed  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model AirdropClaim {
  id          String       @id @default(uuid()) @db.Uuid
  eventId     String       @db.Uuid
  event       AirdropEvent @relation(fields: [eventId], references: [id])
  userId      String       @db.Uuid
  user        User         @relation(fields: [userId], references: [id])
  lamports    BigInt
  txSignature String?
  claimedAt   DateTime     @default(now())

  @@unique([eventId, userId])
}

// $SCAD reward claims (Phase C) — one row per on-chain claim_reward call.
// `period` mirrors the on-chain ClaimRecord PDA seed so the DB and chain
// dedupe agree (dailyCase = YYYYMMDD, airdrop = epoch-hour, others = epoch-ms).
model RewardClaim {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id])
  kind        RewardKind
  period      BigInt
  amountScad  BigInt // SCAD base units (9 decimals)
  // Claim lifecycle (#28): 'pending' (reserved, awaiting on-chain confirm) ->
  // 'confirmed' (txSignature set, debit finalized) | 'failed' (reserve
  // restored). 'offchain' = explicit non-value record while the chain is
  // disabled (dailyCase demo experience). Legacy rows default to 'confirmed'.
  status      String     @default("confirmed")
  attempts    Int        @default(0)
  txSignature String?
  // Provably-fair trail (#22, dailyCase): { tier, roll, serverSeedHash,
  // clientSeed, nonce } from the player's active seed pair — the tier
  // reproduces via @scadium/fair once the server seed is revealed on rotation.
  resultJson  Json?
  createdAt   DateTime   @default(now())

  @@unique([userId, kind, period])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum RewardKind {
  wagerReward
  cashback
  dailyCase
  airdrop
  // Wager-tournament prize payout and free-$SCAD promo grants — both flow
  // through the proven on-chain reward-claim lifecycle.
  tournament
  promo
  // SCAD Engine staker dividend payout, denominated in USDS (not SCAD). Flows
  // through the same reservation-based on-chain claim lifecycle.
  dividend
}

// Buy-and-burn ledger (Phase D): 10% of NGR swapped SOL→SCAD then burned
// (was 20%; the other 10% now funds the staker dividend — see DistributionRound).
model TokenBurn {
  id            String   @id @default(uuid()) @db.Uuid
  scadBurned    BigInt // SCAD base units
  solSpent      BigInt // lamports swapped in
  swapSignature String?
  burnSignature String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// ==================== SCAD ENGINE (staking + GGR dividends) ====================

// Append-only audit of stake/unstake/auto-stake movements of $SCAD into/out of
// the staked balance. Mirrors the BalanceLedger discipline (the matching
// scad/scad_staked ledger rows are written in the same tx by the staking
// service); this table is the engine-specific, queryable history.
model StakeEvent {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  user        User      @relation(fields: [userId], references: [id])
  // 'stake' | 'unstake' | 'auto_stake' (reward-claim auto-stake).
  kind        String
  // SCAD base units moved (always positive; `kind` carries direction).
  amountScad  BigInt
  // Staked balance immediately after this movement (re-derivable).
  stakedAfter BigInt
  // Lock applied (stake/auto_stake) — for the audit trail.
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, createdAt])
}

// One hourly distribution round. NGR over the window since the previous round is
// converted to a USDS pool (ENGINE.DIVIDEND_NGR_BPS) and split pro-rata across
// the staked balances snapshotted at distribution time. `distributed` + `period`
// (unique) make a round idempotent under duplicate worker enqueues.
model DistributionRound {
  id                  String    @id @default(uuid()) @db.Uuid
  // UTC hour key 'YYYYMMDDHH' — one round per hour, unique.
  period              String    @unique
  // NGR (lamports) measured over this round's window.
  ngrLamports         BigInt    @default(0)
  // USDS base units paid out this round (DIVIDEND_NGR_BPS of NGR, in USDS).
  poolUsds            BigInt    @default(0)
  // Sum of staked $SCAD across eligible stakers at distribution time.
  totalStakedSnapshot BigInt    @default(0)
  participantCount    Int       @default(0)
  distributed         Boolean   @default(false)
  distributedAt       DateTime?
  createdAt           DateTime  @default(now())

  claims DistributionClaim[]

  @@index([createdAt])
}

// One staker's share of one distribution round. `@@unique([roundId, userId])`
// guarantees a user is paid at most once per round.
model DistributionClaim {
  id           String            @id @default(uuid()) @db.Uuid
  roundId      String            @db.Uuid
  round        DistributionRound @relation(fields: [roundId], references: [id])
  userId       String            @db.Uuid
  user         User              @relation(fields: [userId], references: [id])
  // Staked $SCAD that earned this share (the weight numerator).
  stakedAmount BigInt
  // USDS base units credited to the user for this round.
  shareUsds    BigInt
  createdAt    DateTime          @default(now())

  @@unique([roundId, userId])
  @@index([userId, createdAt])
}

// ==================== PROOF-OF-WAGER ====================

// Singleton persistent counter of cumulative $SCAD emitted by proof-of-wager.
// The halving schedule (SCAD.EMISSION_PHASES) reads this on the hot accrue path
// to pick the active rate, and `accrue()` atomically increments it (upsert) in
// the SAME tx as the $SCAD credit — so the emission cap (SCAD.P2E_POOL_BASE) is
// enforced concurrency-safely without reconstructing the figure from the ledger
// on every settled bet. Exactly one row exists, id = 'singleton'.
model EmissionState {
  id               String   @id @default("singleton")
  // Cumulative SCAD base units minted by proof-of-wager (≤ SCAD.P2E_POOL_BASE).
  totalEmittedScad BigInt   @default(0)
  updatedAt        DateTime @updatedAt
}

// Time-boxed campaign that layers a MULTIPLIER on top of the base $SCAD wager
// accrual (SCAD.WAGER_REWARD_PER_LAMPORT). `gameType` null = applies to all
// games. ProofOfWagerService caches the active set and combines campaign ×
// lifetime-tier multipliers, capped at WAGER.MAX_MULTIPLIER.
model WagerCampaign {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  multiplier Float
  gameType   GameType?
  startsAt   DateTime
  endsAt     DateTime
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([active, startsAt, endsAt])
}

// Rolling per-period wager totals (lamports) used for daily/weekly leaderboards
// and as the score source for tournaments. `period` is 'daily:YYYYMMDD' or
// 'weekly:YYYYWW' (UTC). Upserted in the settlement transaction by accrue().
model WagerLeaderboard {
  id              String @id @default(uuid()) @db.Uuid
  period          String
  userId          String @db.Uuid
  user            User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wageredLamports BigInt @default(0)

  @@unique([period, userId])
  @@index([period, wageredLamports])
}

// ==================== AFFILIATE ====================

model Referral {
  id                 String   @id @default(uuid()) @db.Uuid
  referrerId         String   @db.Uuid
  referrer           User     @relation("referrer", fields: [referrerId], references: [id])
  refereeId          String   @unique @db.Uuid
  referee            User     @relation("referee", fields: [refereeId], references: [id])
  volumeLamports     BigInt   @default(0)
  commissionLamports BigInt   @default(0)
  // Sybil flag (#47): referrer & referee share a signup IP-hash → volume still
  // tracked but NO commission accrues.
  flagged            Boolean  @default(false)
  createdAt          DateTime @default(now())
}

// ==================== LEADERBOARD ====================

model LeaderboardSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  period         String // 'hourly' | 'daily' | 'weekly' | 'all_time'
  userId         String   @db.Uuid
  volumeLamports BigInt
  rank           Int
  capturedAt     DateTime @default(now())

  @@index([period, capturedAt, rank])
}

// Dead-letter record for a game settlement that exhausted its serializable
// retries. The round is left non-terminal so a recovery worker (Phase H) can
// re-settle it; payloadJson captures a JSON-safe summary (BigInts stringified)
// of the round/bets so the failure can be replayed or audited.
model SettlementFailure {
  id          String   @id @default(uuid()) @db.Uuid
  gameType    GameType
  roundId     String
  payloadJson Json
  error       String
  createdAt   DateTime @default(now())

  @@index([gameType, createdAt])
}

// Idempotency keys (Phase G): opt-in client-supplied request dedupe. When a
// command receives an `Idempotency-Key` header, it claims a row keyed by
// (userId, scope, clientKey) at the TOP of its transaction and stores the
// JSON-safe response at the end. A retry with the same key replays the stored
// response instead of re-executing — the unique constraint makes the claim a
// compare-and-swap. `responseJson` is null while in-flight (a concurrent retry
// then 409s) and set once the command commits.
model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  scope        String
  clientKey    String
  responseJson Json?
  createdAt    DateTime @default(now())

  @@unique([userId, scope, clientKey])
}

/// AML audit trail for geo/VPN access decisions (#43). Raw IPs are NEVER stored
/// — only a salted hash, the resolved country and the VPN score.
model GeoCheck {
  id        String   @id @default(uuid()) @db.Uuid
  ipHash    String
  country   String?
  vpnScore  Float?
  allowed   Boolean
  path      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/// SCAD Vault asset. Faz 1 ships `scad` only; the rest are reserved for the
/// on-chain custody phase (real SOL/USDC + liquid-staking/lending yield).
enum VaultAsset {
  scad
  usds
  sol
  usdc
}

/// SCAD Vault term pool — one row per (asset, termDays). The Vault is the LOCKED,
/// term-based tier (the Engine is the liquid one). Accounting is share/index
/// based (ERC-4626-style): `indexRay` is the share price (1e18 fixed-point);
/// yield raises the index so every position appreciates pro-rata in O(1).
/// `weightBps` is the pool's RELATIVE weight when the Vault NGR yield slice is
/// split across pools (longer term → larger weight → higher effective APR).
/// Off-chain-first: this is the source of truth today; once the chain is live it
/// becomes a cache of the on-chain pool (mirrors VaultTransfer / dividends).
model VaultPool {
  id            String     @id @default(cuid())
  asset         VaultAsset
  termDays      Int
  totalAssets   BigInt     @default(0)
  totalShares   BigInt     @default(0)
  indexRay      BigInt     @default(1000000000000000000)
  weightBps     Int
  aprBps        Int        @default(0)
  active        Boolean    @default(true)
  lastAccrualAt DateTime   @default(now())
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  positions VaultPosition[]
  events    VaultEvent[]

  @@unique([asset, termDays])
}

/// A user's stake in one term pool. `shares` track the ERC-4626 claim; `principal`
/// is the net asset deposited (earned = currentValue − principal). `maturesAt` is
/// the term end — an early (pre-maturity) withdrawal is allowed but charged
/// VAULT.EARLY_EXIT_PENALTY_BPS, which stays in the pool (raising the index).
model VaultPosition {
  id        String    @id @default(cuid())
  userId    String    @db.Uuid
  poolId    String
  shares    BigInt    @default(0)
  principal BigInt    @default(0)
  maturesAt DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User      @relation(fields: [userId], references: [id])
  pool VaultPool @relation(fields: [poolId], references: [id])

  @@index([userId])
  @@index([poolId])
}

/// Append-only Vault ledger: one row per deposit / withdraw / early_exit / accrue.
/// `assetsDelta` / `sharesDelta` are signed; `penaltyAssets` records an early-exit
/// cut; `indexRayAfter` snapshots the post-event share price. `txSignature` is the
/// on-chain bridge handle (null off-chain; @unique so a confirmed tx credits once).
model VaultEvent {
  id            String   @id @default(cuid())
  userId        String?  @db.Uuid
  poolId        String
  kind          String
  assetsDelta   BigInt
  sharesDelta   BigInt
  penaltyAssets BigInt   @default(0)
  indexRayAfter BigInt
  txSignature   String?  @unique
  createdAt     DateTime @default(now())

  pool VaultPool @relation(fields: [poolId], references: [id])

  @@index([userId])
  @@index([poolId])
}

/// One Vault yield-accrual round per UTC hour (mirrors DistributionRound).
/// Idempotent via `period` unique + the `distributed` flag, so a re-fire of the
/// same hour credits no yield twice. `yieldScad` is the total $SCAD the Vault's
/// NGR slice added across pools that round.
model VaultAccrualRound {
  id            String    @id @default(cuid())
  period        String    @unique
  ngrLamports   BigInt    @default(0)
  yieldScad     BigInt    @default(0)
  poolCount     Int       @default(0)
  distributed   Boolean   @default(false)
  distributedAt DateTime?
  createdAt     DateTime  @default(now())
}
