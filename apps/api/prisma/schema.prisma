// Scadium Prisma schema — single source of truth for the Postgres DB.
// Run migrations with `pnpm --filter @scadium/api prisma migrate dev`.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ENUMS ====================

enum Role {
  user
  moderator
  admin
}

enum GameType {
  crash
  coinflip
  blackjack
  lottery
  jackpot
}

enum LotteryDrawStatus {
  open
  drawn
}

enum JackpotRoundStatus {
  open
  drawn
  refunded
}

enum BetStatus {
  pending
  won
  lost
  refunded
}

enum CrashRoundStatus {
  waiting
  running
  busted
}

enum CoinflipStatus {
  open
  matched
  resolving
  completed
  cancelled
}

enum BlackjackTableStatus {
  waiting
  betting
  dealing
  player_turns
  dealer_turn
  settling
}

// ==================== USERS & AUTH ====================

model User {
  id             String   @id @default(uuid()) @db.Uuid
  walletAddress  String   @unique
  username       String?  @unique
  avatarUrl      String?
  // Optional contact + linked socials (Settings). Social fields hold the
  // linked handle/email per provider; null = not connected.
  email          String?
  googleAccount  String?
  telegramAccount String?
  discordAccount String?
  // Notification preferences.
  notifyEmailWins Boolean @default(false)
  notifyMarketing Boolean @default(false)
  role           Role     @default(user)
  refCode        String   @unique
  referredById   String?  @db.Uuid
  referredBy     User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]   @relation("Referrals")
  banned         Boolean  @default(false)
  banReason      String?
  totalWagered   BigInt   @default(0)
  totalWon       BigInt   @default(0)
  totalLost      BigInt   @default(0)
  biggestWin     BigInt   @default(0)
  gamesPlayed    Int      @default(0)
  scadiumBalance BigInt   @default(0)
  // Play-money balance used by the off-chain game loop until on-chain
  // programs land. New users get 10 SOL equivalent (10_000_000_000 lamports).
  // Once the vault is live this becomes a CACHE of the on-chain UserVault
  // balance (reconciled periodically) — fast validation stays in Postgres.
  playBalanceLamports BigInt @default(10000000000)
  // On-chain custody (Phase A): UserVault PDA address once the user has
  // deposited at least once; null = never deposited (still play-money).
  vaultAddress   String?  @unique
  lastDailyCaseAt DateTime?
  // "Reset Stats" timestamp — when set, the lifetime stats grid counts only
  // bets settled after this instant (computed from the Bet table). null =
  // show the denormalized User aggregate columns (fast path).
  statsResetAt   DateTime?
  // totalLost watermark at the last cashback claim — cashback accrues on
  // the delta since this baseline (Phase C).
  cashbackBaselineLost BigInt @default(0)
  // totalWagered watermark for free lottery tickets — every 1 SOL wagered
  // above this earns one; consuming a ticket advances it by 1 SOL.
  freeTicketBaselineWagered BigInt @default(0)
  rewardClaims   RewardClaim[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions       Session[]
  bets           Bet[]
  chatMessages   ChatMessage[]
  crashBets      CrashBet[]
  scheduledCrashBets ScheduledCrashBet[]
  coinflipsMade  CoinflipGame[] @relation("creator")
  coinflipsJoined CoinflipGame[] @relation("joiner")
  airdropClaims  AirdropClaim[]
  referralsAsReferrer Referral[] @relation("referrer")
  referralsAsReferee  Referral[] @relation("referee")
  lotteryTickets LotteryTicket[]
  jackpotEntries JackpotEntry[]
  jackpotWins    JackpotRound[] @relation("jackpotWinner")
  linkedWallets  LinkedWallet[]
  balanceLedger  BalanceLedger[]
  reconciliationDrifts ReconciliationDrift[]
  auditLogsAsActor  AuditLog[] @relation("auditActor")
  auditLogsAsTarget AuditLog[] @relation("auditTarget")

  @@index([walletAddress])
  @@index([refCode])
}

// Additional Solana wallets linked to an account (beyond the primary
// User.walletAddress). Sign-in with any linked address resolves to the owning
// user; ownership is proven once via a SIWS signature at link time.
model LinkedWallet {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  address   String   @unique
  createdAt DateTime @default(now())

  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jwtId        String   @unique
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
}

// Append-only double-entry ledger (Phase G): one row per playBalance movement,
// written in the SAME transaction as the mutation via `applyBalanceDelta`. This
// makes `User.playBalanceLamports` a re-derivable projection — SUM(delta) per
// user must equal the live balance, and `balanceAfter` is the running sum at the
// time the row was written. Never updated or deleted by application code.
model BalanceLedger {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  delta        BigInt
  reason       String
  refType      String
  refId        String?
  balanceAfter BigInt
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// Reconciliation drift log (Phase G): the hourly reconciliation job recomputes
// per-user aggregates from `Bet` + `BalanceLedger` and, for each User column
// that disagrees with the recomputed value, appends one flag row here. The job
// NEVER mutates the User row — it only flags. `storedValue`/`derivedValue` are
// stringified (lamports are BigInt; gamesPlayed is an Int) for safe transport.
model ReconciliationDrift {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id])
  field        String
  storedValue  String
  derivedValue String
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

// Append-only audit log (Phase G) for privileged admin actions (ban / unban /
// forced airdrop distribution). Written in the SAME transaction as the action
// it records so the audit row commits (or rolls back) atomically with the
// effect. Never updated or deleted by application code.
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  actorUserId  String   @db.Uuid
  actor        User     @relation("auditActor", fields: [actorUserId], references: [id])
  action       String
  targetUserId String?  @db.Uuid
  target       User?    @relation("auditTarget", fields: [targetUserId], references: [id])
  metadataJson Json?
  createdAt    DateTime @default(now())

  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model AuthNonce {
  walletAddress String   @id
  nonce         String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}

// ==================== FAIRNESS ====================

model Seed {
  id              String    @id @default(uuid()) @db.Uuid
  serverSeedHash  String    @unique
  serverSeed      String?   @unique
  clientSeed      String
  nonce           Int       @default(0)
  revealedAt      DateTime?
  createdAt       DateTime  @default(now())

  crashRounds   CrashRound[]
  coinflips     CoinflipGame[]
  blackjackRounds BlackjackRound[]
  lotteryDraws  LotteryDraw[]
  jackpotRounds JackpotRound[]
}

// ==================== BETS (unified history) ====================

model Bet {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  user            User      @relation(fields: [userId], references: [id])
  gameType        GameType
  amountLamports  BigInt
  payoutLamports  BigInt    @default(0)
  multiplier      Float?
  status          BetStatus @default(pending)
  txSignature     String?
  seedId          String?   @db.Uuid
  nonce           Int?
  resultJson      Json?
  createdAt       DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([gameType, createdAt])
}

// ==================== CRASH ====================

model CrashRound {
  id              String            @id @default(uuid()) @db.Uuid
  seedId          String            @db.Uuid
  seed            Seed              @relation(fields: [seedId], references: [id])
  nonce           Int
  status          CrashRoundStatus  @default(waiting)
  bustMultiplier  Float?
  startedAt       DateTime?
  endedAt         DateTime?
  createdAt       DateTime          @default(now())

  bets CrashBet[]

  @@index([status, createdAt])
}

model CrashBet {
  id                    String   @id @default(uuid()) @db.Uuid
  roundId               String   @db.Uuid
  round                 CrashRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId                String   @db.Uuid
  user                  User     @relation(fields: [userId], references: [id])
  amountLamports        BigInt
  // Stake still riding (RAM-only until persisted at bet/cashout time). Shrinks
  // to 0 on a full cashout and on settle/recovery; recovery refunds whatever
  // remains so a crashed mid-round bet is never stranded.
  remainingLamports     BigInt   @default(0)
  autoCashoutMultiplier Float?
  cashoutMultiplier     Float?
  payoutLamports        BigInt   @default(0)
  won                   Boolean  @default(false)
  createdAt             DateTime @default(now())

  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId])
}

// A next-round crash bet whose stake has been DEBITED but whose round has not
// opened yet. Persisted at schedule time (in the same tx as the debit) so a
// restart in the window before `startNewRound` drains the in-memory queue can
// still refund the stake (#72). The row is deleted atomically when the bet is
// drained into a real CrashBet, when cancelled, or when refunded on boot
// recovery. One scheduled bet per user (mirrors the engine's in-memory Map).
model ScheduledCrashBet {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @db.Uuid @unique
  user                  User     @relation(fields: [userId], references: [id])
  amountLamports        BigInt
  autoCashoutMultiplier Float?
  createdAt             DateTime @default(now())
}

// ==================== COINFLIP ====================

model CoinflipGame {
  id             String         @id @default(uuid()) @db.Uuid
  creatorId      String         @db.Uuid
  creator        User           @relation("creator", fields: [creatorId], references: [id])
  creatorSide    String         // 'heads' | 'tails'
  joinerId       String?        @db.Uuid
  joiner         User?          @relation("joiner", fields: [joinerId], references: [id])
  amountLamports BigInt
  result         String?        // 'heads' | 'tails'
  winnerId       String?        @db.Uuid
  status         CoinflipStatus @default(open)
  seedId         String?        @db.Uuid
  seed           Seed?          @relation(fields: [seedId], references: [id])
  nonce          Int?
  txSignature    String?
  createdAt      DateTime       @default(now())
  resolvedAt     DateTime?

  @@index([status, createdAt])
  @@index([creatorId])
}

// ==================== LOTTERY ====================

model LotteryDraw {
  id           String            @id @default(uuid()) @db.Uuid
  // Monotonic on-chain draw index (PDA seed). Null for legacy off-chain draws.
  drawIndex    BigInt?           @unique
  commitTxSignature String?
  revealTxSignature String?
  seedId       String            @db.Uuid
  seed         Seed              @relation(fields: [seedId], references: [id])
  nonce        Int               @default(0)
  status       LotteryDrawStatus @default(open)
  // Result (empty until drawn): the 6 winning digits (each 0..9), index 0 =
  // leftmost. Tickets win the highest bracket whose leading digits all match.
  winningDigits Int[]
  // Hex of the 32-byte slot hash mixed into the draw entropy (null until
  // drawn; synthetic sha256(seed:clientSeed) when the chain is disabled).
  slotHash     String?
  // PancakeSwap-style $SCAD economy (all base units, 9 decimals):
  ticketPriceScadBase     BigInt   @default(0) // price per ticket this round
  injectionScadBase       BigInt   @default(0) // house injection added to the pool
  rolloverScadBase        BigInt   @default(0) // unwon slices carried in from prior round
  totalPoolScadBase       BigInt   @default(0) // sales(discounted) + injection + rollover
  burnScadBase            BigInt   @default(0) // 20% treasury slice burned at settle
  bracketWinnerCounts     Int[]                // [6] winners per bracket
  bracketAmountsScadBase  BigInt[]             // [6] slice per bracket
  bracketRolloverScadBase BigInt[]             // [6] unwon slice rolled forward
  // SOL-equivalent of the round's ticket sales — kept ONLY for the unified Bet
  // ledger / aggregates (real value moves in $SCAD).
  potLamports  BigInt            @default(0)
  ticketCount  Int               @default(0)
  drawAt       DateTime // when this draw is scheduled to resolve
  drawnAt      DateTime?
  createdAt    DateTime          @default(now())

  tickets LotteryTicket[]

  @@index([status, drawAt])
}

model LotteryTicket {
  id             String      @id @default(uuid()) @db.Uuid
  drawId         String      @db.Uuid
  draw           LotteryDraw @relation(fields: [drawId], references: [id])
  userId         String      @db.Uuid
  user           User        @relation(fields: [userId], references: [id])
  digits         Int[] // the 6 picked digits (each 0..9), index 0 = leftmost
  // SOL-equiv mirrors for the unified Bet ledger; real value is the *ScadBase.
  costLamports   BigInt
  payoutLamports BigInt      @default(0)
  costScadBase   BigInt      @default(0) // $SCAD actually paid (after bulk-discount share)
  payoutScadBase BigInt      @default(0) // $SCAD prize from its bracket's equal split
  matchLen       Int         @default(0) // leading digits matched (0..6)
  bracket        Int? // highest bracket won (0..5), null if no win
  won            Boolean     @default(false)
  // On-chain era: purchase tx (user-signed $SCAD transfer), prize payout tx,
  // and the free-ticket flag (loyalty entry on the house).
  // A bulk buy_tickets tx records N tickets under one signature — txIndex is
  // the ticket's position in the batch; (txSignature, txIndex) blocks replays.
  txSignature    String?
  txIndex        Int         @default(0)
  prizeTxSignature String?
  free           Boolean     @default(false)
  createdAt      DateTime    @default(now())

  @@unique([txSignature, txIndex])
  @@index([drawId])
  @@index([userId, createdAt])
}

// ==================== JACKPOT ====================

model JackpotRound {
  id             String             @id @default(uuid()) @db.Uuid
  seedId         String             @db.Uuid
  seed           Seed               @relation(fields: [seedId], references: [id])
  nonce          Int                @default(0)
  status         JackpotRoundStatus @default(open)
  totalLamports  BigInt             @default(0) // sum of all entries
  winnerId       String?            @db.Uuid
  winner         User?              @relation("jackpotWinner", fields: [winnerId], references: [id])
  winningTicket  BigInt? // the drawn lamport index in [0, totalLamports)
  payoutLamports BigInt             @default(0) // amount paid to the winner (after edge)
  closeAt        DateTime // when the open window ends and the draw runs
  drawnAt        DateTime?
  createdAt      DateTime           @default(now())

  entries JackpotEntry[]

  @@index([status, closeAt])
}

model JackpotEntry {
  id             String       @id @default(uuid()) @db.Uuid
  roundId        String       @db.Uuid
  round          JackpotRound @relation(fields: [roundId], references: [id])
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id])
  amountLamports BigInt
  createdAt      DateTime     @default(now())

  @@unique([roundId, userId])
  @@index([roundId])
  @@index([userId, createdAt])
}

// ==================== BLACKJACK ====================

model BlackjackTable {
  id                String                @id @default(uuid()) @db.Uuid
  name              String
  status            BlackjackTableStatus  @default(waiting)
  minBetLamports    BigInt
  maxBetLamports    BigInt
  maxSeats          Int                   @default(5)
  createdAt         DateTime              @default(now())

  rounds BlackjackRound[]
}

model BlackjackRound {
  id         String         @id @default(uuid()) @db.Uuid
  tableId    String         @db.Uuid
  table      BlackjackTable @relation(fields: [tableId], references: [id])
  seedId     String         @db.Uuid
  seed       Seed           @relation(fields: [seedId], references: [id])
  nonce      Int
  stateJson  Json
  endedAt    DateTime?
  createdAt  DateTime       @default(now())

  @@index([tableId, createdAt])
}

// ==================== CHAT ====================

model ChatMessage {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  user       User     @relation(fields: [userId], references: [id])
  body       String
  deletedAt  DateTime?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// ==================== AIRDROPS / REWARDS ====================

model AirdropEvent {
  id              String   @id @default(uuid()) @db.Uuid
  distributedAt   DateTime @default(now())
  totalLamports   BigInt
  participantCount Int

  claims AirdropClaim[]
}

// Accumulating pool for the CURRENT hour (solpump left-rail airdrop widget).
// Survives API restarts because tips debit real play balances. One row per
// hour (`period` = YYYYMMDDHH UTC); flipped to distributed by the engine.
model AirdropPool {
  id           String   @id @default(uuid()) @db.Uuid
  period       String   @unique
  baseLamports BigInt   @default(0)
  tipLamports  BigInt   @default(0)
  tipsCount    Int      @default(0)
  distributed  Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model AirdropClaim {
  id             String       @id @default(uuid()) @db.Uuid
  eventId        String       @db.Uuid
  event          AirdropEvent @relation(fields: [eventId], references: [id])
  userId         String       @db.Uuid
  user           User         @relation(fields: [userId], references: [id])
  lamports       BigInt
  txSignature    String?
  claimedAt      DateTime     @default(now())

  @@unique([eventId, userId])
}

// $SCAD reward claims (Phase C) — one row per on-chain claim_reward call.
// `period` mirrors the on-chain ClaimRecord PDA seed so the DB and chain
// dedupe agree (dailyCase = YYYYMMDD, airdrop = epoch-hour, others = epoch-ms).
model RewardClaim {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  user        User       @relation(fields: [userId], references: [id])
  kind        RewardKind
  period      BigInt
  amountScad  BigInt // SCAD base units (9 decimals)
  txSignature String?
  createdAt   DateTime   @default(now())

  @@unique([userId, kind, period])
  @@index([userId, createdAt])
}

enum RewardKind {
  wagerReward
  cashback
  dailyCase
  airdrop
}

// Buy-and-burn ledger (Phase D): 20% of NGR swapped SOL→SCAD then burned.
model TokenBurn {
  id           String   @id @default(uuid()) @db.Uuid
  scadBurned   BigInt // SCAD base units
  solSpent     BigInt // lamports swapped in
  swapSignature String?
  burnSignature String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

// ==================== AFFILIATE ====================

model Referral {
  id                  String   @id @default(uuid()) @db.Uuid
  referrerId          String   @db.Uuid
  referrer            User     @relation("referrer", fields: [referrerId], references: [id])
  refereeId           String   @unique @db.Uuid
  referee             User     @relation("referee", fields: [refereeId], references: [id])
  volumeLamports      BigInt   @default(0)
  commissionLamports  BigInt   @default(0)
  createdAt           DateTime @default(now())
}

// ==================== LEADERBOARD ====================

model LeaderboardSnapshot {
  id             String   @id @default(uuid()) @db.Uuid
  period         String   // 'hourly' | 'daily' | 'weekly' | 'all_time'
  userId         String   @db.Uuid
  volumeLamports BigInt
  rank           Int
  capturedAt     DateTime @default(now())

  @@index([period, capturedAt, rank])
}

// Dead-letter record for a game settlement that exhausted its serializable
// retries. The round is left non-terminal so a recovery worker (Phase H) can
// re-settle it; payloadJson captures a JSON-safe summary (BigInts stringified)
// of the round/bets so the failure can be replayed or audited.
model SettlementFailure {
  id          String   @id @default(uuid()) @db.Uuid
  gameType    GameType
  roundId     String
  payloadJson Json
  error       String
  createdAt   DateTime @default(now())

  @@index([gameType, createdAt])
}

// Idempotency keys (Phase G): opt-in client-supplied request dedupe. When a
// command receives an `Idempotency-Key` header, it claims a row keyed by
// (userId, scope, clientKey) at the TOP of its transaction and stores the
// JSON-safe response at the end. A retry with the same key replays the stored
// response instead of re-executing — the unique constraint makes the claim a
// compare-and-swap. `responseJson` is null while in-flight (a concurrent retry
// then 409s) and set once the command commits.
model IdempotencyKey {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid
  scope        String
  clientKey    String
  responseJson Json?
  createdAt    DateTime @default(now())

  @@unique([userId, scope, clientKey])
}
