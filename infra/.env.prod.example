# ─────────────────────────────────────────────────────────────────────────────
# Scadium production demo — single-VPS Docker Compose env
#
# Copy to infra/.env.prod ON THE VPS and fill in real values:
#     cp infra/.env.prod.example infra/.env.prod
# Then bring the stack up:
#     docker compose --env-file infra/.env.prod -f infra/docker-compose.prod.yml up -d --build
#
# infra/.env.prod is gitignored. NEVER commit real secrets.
# Generate strong secrets on the box:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# Base domain. DNS A records app.<DOMAIN> and api.<DOMAIN> must point at this VPS
# BEFORE first `up`, or Caddy's Let's Encrypt challenge fails.
DOMAIN=example.com

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=scadium
POSTGRES_PASSWORD=replace-with-openssl-rand-hex-32
POSTGRES_DB=scadium
# The API + Prisma connect over the internal compose network (host = `postgres`).
DATABASE_URL=postgresql://scadium:replace-with-openssl-rand-hex-32@postgres:5432/scadium?schema=public

# ── API ─────────────────────────────────────────────────────────────────────
# Strong random; the API refuses to boot in production with the dev fallback.
JWT_SECRET=replace-with-openssl-rand-hex-32
JWT_ACCESS_TTL=24h
# Allowed browser origin for REST + Socket.io CORS. Must match the web origin exactly.
CORS_ORIGIN=https://app.example.com
# Rate limiting (per client IP, requires trust-proxy which is set in main.ts).
# Demo-generous so normal polling never trips it while still blocking spam.
THROTTLE_TTL=60
THROTTLE_LIMIT=600
#
# PLAY-MONEY MODE: intentionally DO NOT set VAULT_PROGRAM_ID / SWAP_PROGRAM_ID /
# LOTTERY_PROGRAM_ID / COSIGNER_KEYPAIR_PATH / SCAD_MINT / USDS_MINT. With these
# unset the API disables on-chain settlement and every game runs on the Postgres
# play balance. USDS_MINT is the SCAD Engine dividend stablecoin mint (claim_dividend).

# ── Privy social login (Google/Apple, #235) ──────────────────────────────────
# OPTIONAL. All THREE must be set TOGETHER (PRIVY_APP_ID + PRIVY_APP_SECRET on the
# API, NEXT_PUBLIC_PRIVY_APP_ID baked into the web bundle). If any is missing the
# API fails CLOSED — /auth/privy returns 503 and the social buttons are hidden —
# rather than trusting the client. Values come from the Privy dashboard; the App
# Secret is server-only and must NEVER be exposed to the browser (no NEXT_PUBLIC_).
#PRIVY_APP_ID=
#PRIVY_APP_SECRET=
#NEXT_PUBLIC_PRIVY_APP_ID=

# ── Web (NEXT_PUBLIC_* are baked into the bundle at BUILD time, via build.args) ──
# Point at the api subdomain; wss:// for Socket.io behind TLS.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com
# Wallet-adapter still connects burner/extension wallets; nothing is spent in demo.
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_APP_NAME=Scadium
